# ─── YouTube Stream Manager — Environment Configuration ───
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env

# ─── REQUIRED: YouTube Data API v3 Key ───
# Get it from: https://console.cloud.google.com/apis/credentials
# Enable: YouTube Data API v3
# Without this: search won't work, live stream detection won't work
YOUTUBE_API_KEY=""

# ─── OPTIONAL: Google OAuth 2.0 Credentials ───
# Needed for: connecting YouTube accounts, creating/managing broadcasts
# Get from: https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID (Web application type)
#
# IMPORTANT: Add this exact URL to Authorized Redirect URIs in Google Cloud Console:
#   http://localhost:3000/api/auth/google/callback
# (Replace localhost:3000 with your actual domain in production)
OAUTH_CLIENT_ID=""
OAUTH_CLIENT_SECRET=""
OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# ─── OPTIONAL: App URL ───
# Used for OAuth callbacks and self-referential links
# Default: http://localhost:3000
APP_URL="http://localhost:3000"

# ─── OPTIONAL: Vite allowed hosts ───
# Add hostnames that can access the Vite dev server (comma-separated)
# Example: VITE_ALLOWED_HOSTS=my-server.com,203.0.113.5
# Set to 'true' (default) to allow all hosts
VITE_ALLOWED_HOSTS=true
